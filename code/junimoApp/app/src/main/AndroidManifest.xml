<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!--
        US 01.06.01
        Camera permission required for QR code scanning in QRScanActivity.
        android:required="false" means the app installs on devices without
        a camera — the scan button just won't work on those devices.
    -->
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-feature android:name="android.hardware.camera" android:required="false" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.JunimoApp">

        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- User-side activities -->
        <activity android:name=".UserHomeActivity" />
        <activity android:name=".InvitationsActivity" />
        <activity android:name=".ProfileActivity" />
        <activity android:name=".GuidelinesActivity"/>
        <activity android:name=".EventDetailsActivity"/>
        <activity android:name=".UserNotificationsActivity" />
        <activity android:name=".EventSearchActivity" />
        <activity android:name=".EventHistory" />

        <!--
            US 01.06.01
            QRScanActivity opens the camera, scans Junimo event QR codes,
            and navigates to EventDetailsActivity with the parsed eventId.
        -->
        <activity android:name=".QRScanActivity" />

        <!-- Organizer activities -->
        <activity android:name=".OrganizerStartScreen" />
        <activity android:name=".Organizer.CreateEvent" />
        <activity android:name=".Organizer.EventPreview" />
        <activity android:name=".Organizer.Entrants" />
        <activity android:name=".Organizer.organizerNotifications" />
        <activity android:name=".Organizer.SelectAnEvent" />

        <!--
            US 02.01.03
            PrivateInviteActivity lets the organizer search and invite
            entrants to a private event waiting list.
        -->
        <activity android:name=".Organizer.PrivateInviteActivity" />

        <!-- Admin activities -->
        <activity android:name=".admin.AdminHomeActivity" />
        <activity android:name=".admin.AdminBrowseEventsActivity" />
        <activity android:name=".admin.AdminBrowseProfilesActivity" />
        <activity android:name=".admin.AdminBrowseImagesActivity" />
        <activity android:name=".admin.AdminBrowseOrganizersActivity" />
        <activity android:name=".admin.AdminEventDetailActivity" />
        <activity android:name=".admin.AdminNotificationLogActivity" />

    </application>

</manifest>

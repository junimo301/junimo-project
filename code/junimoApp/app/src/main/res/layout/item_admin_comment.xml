<?xml version="1.0" encoding="utf-8"?>

<!-- Layout for one comment row (US 03.10.01) -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="horizontal"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="12dp"
    android:gravity="center_vertical">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/adminCommentAuthor"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#AFAFAF"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/adminCommentText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#AFAFAF"
            android:textSize="12sp" />
    </LinearLayout>

    <Button
        android:id="@+id/adminCommentDeleteButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:backgroundTint="#C0392B"
        android:text="@string/remove_comment"
        android:textColor="#FFFFFF"
        android:textSize="12sp" />

</LinearLayout>
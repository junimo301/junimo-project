<?xml version="1.0" encoding="utf-8"?>
<!--
    US 01.06.01
    Layout for QRScanActivity.
    The DecoratedBarcodeView fills the screen and shows the camera preview
    with a built-in scan overlay from the ZXing library.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:orientation="vertical">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:layout_marginStart="16dp"
        android:text="Scan Event QR Code"
        android:textColor="#FFFFFF"
        android:textSize="20sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="8dp"
        android:text="Point your camera at a Junimo event QR code"
        android:textColor="#D2D2D2"
        android:textSize="14sp" />

    <!--
        US 01.06.01
        DecoratedBarcodeView from ZXing — handles camera preview,
        scanning, and the targeting overlay automatically.
    -->
    <com.journeyapps.barcodescanner.DecoratedBarcodeView
        android:id="@+id/barcode_scanner"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

</LinearLayout>
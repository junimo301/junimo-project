<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/event_lottery"
                    android:textColor="#FFFFFF"
                    android:textSize="28sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#D2D2D2"
                    android:textSize="18sp" />
            </LinearLayout>

            <ImageButton
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@android:color/transparent"
                android:contentDescription="@string/settings"
                android:src="@android:drawable/ic_menu_manage"
                app:tint="#FFFFFF" />
        </LinearLayout>

        <!-- PAGE DETAILS -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="12dp"
            android:background="#2A2A2A" />

        <TextView
            android:id="@+id/backButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="@string/back_to_home"
            android:textColor="#FFFFFF"
            android:textSize="18sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/create_new_event"
            android:textColor="#FFFFFF"
            android:textSize="42sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="#3A3A3A"
            android:orientation="vertical"
            android:padding="14dp">

            <!-- EVENT DETAILS -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/spec_title"
                android:textColor="#E6E6E6"
                android:textSize="16sp" />

            <EditText
                android:id="@+id/edit_title"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:background="@android:color/transparent"
                android:inputType="text"
                android:paddingStart="2dp"
                android:textColor="#FFFFFF"
                android:textColorHint="#AFAFAF" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#8C8C8C" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/description"
                android:textColor="#E6E6E6"
                android:textSize="16sp" />

            <EditText
                android:id="@+id/edit_description"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:inputType="text"
                android:background="@android:color/transparent"
                android:textColor="#FFFFFF"
                android:textColorHint="#AFAFAF" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#8C8C8C" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/spec_date"
                android:textColor="#E6E6E6"
                android:textSize="16sp" />

            <EditText
                android:id="@+id/edit_date"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:inputType="date"
                android:background="@android:color/transparent"
                android:textColor="#FFFFFF"
                android:textColorHint="#AFAFAF" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#8C8C8C" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/spec_location"

                android:textColor="#E6E6E6"
                android:textSize="16sp" />

            <EditText
                android:id="@+id/edit_event_location"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:inputType="text"
                android:background="@android:color/transparent"
                android:textColor="#FFFFFF"
                android:textColorHint="#AFAFAF" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#8C8C8C" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/spec_max_capacity"
                android:textColor="#E6E6E6"
                android:textSize="16sp" />

            <EditText
                android:id="@+id/edit_max_capacity"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:background="@android:color/transparent"
                android:inputType="number"
                android:textColor="#FFFFFF"
                android:textColorHint="#AFAFAF" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#8C8C8C" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/registration_period"
                android:textColor="#E6E6E6"
                android:textSize="16sp" />

            <EditText
                android:id="@+id/edit_start_date"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:background="@android:color/transparent"
                android:hint="@string/start"
                android:inputType="date"
                android:textColor="#FFFFFF"
                android:textColorHint="#AFAFAF" />

            <EditText
                android:id="@+id/edit_end_date"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:background="@android:color/transparent"
                android:inputType="date"
                android:hint="@string/end"
                android:textColor="#FFFFFF"
                android:textColorHint="#AFAFAF" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#8C8C8C" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/waiting_list_limit"
                android:textColor="#E6E6E6"
                android:textSize="16sp" />

            <EditText
                android:id="@+id/edit_waiting_list"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:background="@android:color/transparent"
                android:inputType="number"
                android:textColor="#FFFFFF"
                android:textColorHint="#AFAFAF" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#8C8C8C" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/spec_price"
                android:textColor="#E6E6E6"
                android:textSize="16sp" />

            <EditText
                android:id="@+id/edit_price"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:background="@android:color/transparent"
                android:inputType="numberDecimal"
                android:textColor="#FFFFFF"
                android:textColorHint="#AFAFAF" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#8C8C8C" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#8C8C8C"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/event_tag_prompt"
                android:textColor="#E6E6E6"
                android:textSize="16sp" />

            <Spinner
                android:id="@+id/edit_tag_spinner"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:background="@android:color/transparent"
                android:entries="@array/event_tags" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="12dp"
                android:background="#8C8C8C" />

            <!-- ============================================================
                 US 02.01.02
                 Private Event checkbox.
                 When checked:
                   - the QR Generate button above is disabled
                   - isPrivate is saved as true in Firestore
                   - this event will NOT show in the public event listing
                 ============================================================ -->
            <CheckBox
                android:id="@+id/check_private_event"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/private_event_invite_only_no_qr_code"
                android:textColor="#E6E6E6"
                android:textSize="16sp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="12dp"
                android:background="#8C8C8C" />

            <!-- GEO LOCATION -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="22dp"
                android:layout_marginTop="12dp"
                android:text="@string/spec_geo_location"
                android:textColor="#E6E6E6"
                android:textSize="16sp" />
            <Button
                android:id="@+id/enable_geoLocation"
                android:layout_width="120dp"
                android:layout_height="40dp"
                android:layout_marginTop="8dp"
                android:backgroundTint="#D9D9D9"
                android:text="@string/enable"
                android:textAllCaps="false"
                android:textColor="#000000" />

            <!-- POSTER -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/poster"
                android:textColor="#E6E6E6"
                android:textSize="16sp" />
            <Button
                android:id="@+id/pick_image_button"
                android:layout_width="120dp"
                android:layout_height="40dp"
                android:layout_marginTop="8dp"
                android:backgroundTint="#D9D9D9"
                android:text="@string/upload"
                android:textAllCaps="false"
                android:textColor="#000000" />
            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:id="@+id/event_poster"
                android:scaleType="centerCrop"
                android:src="@drawable/bg_event_tile"
                android:alpha="0.37"/>

            <!-- QR CODE -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/generate_qr_code"
                android:textColor="#E6E6E6"
                android:textSize="16sp" />

            <Button
                android:id="@+id/QR_code_button"
                android:layout_width="120dp"
                android:layout_height="40dp"
                android:layout_marginTop="8dp"
                android:backgroundTint="#D9D9D9"
                android:text="@string/generate"
                android:textAllCaps="false"
                android:textColor="#000000" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="@string/fields_with_must_be_filled_in"
                android:textColor="#B0B0B0"
                android:textSize="13sp" />
        </LinearLayout>

        <!-- BUTTONS -->
        <Button
            android:id="@+id/preview_event_button"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="16dp"
            android:backgroundTint="#EAEAEA"
            android:text="@string/preview"
            android:textAllCaps="false"
            android:textColor="#000000" />

        <Button
            android:id="@+id/upload_event_button"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="10dp"
            android:backgroundTint="#EAEAEA"
            android:text="@string/publish"
            android:textAllCaps="false"
            android:textColor="#000000"
            android:textStyle="bold" />

        <Button
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="12dp"
            android:backgroundTint="#EAEAEA"
            android:text="@string/cancel"
            android:textAllCaps="false"
            android:textColor="#000000"
            android:id="@+id/cancel_button" />

    </LinearLayout>

</ScrollView>

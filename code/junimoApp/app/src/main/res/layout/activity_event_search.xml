<?xml version="1.0" encoding="utf-8"?>
<!-- UI for US 01.01.04, 01.01.05 and 01.01.06. Allows users to search by keyword, tag, date and capacity ranges -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:padding="16dp">

    <!-- BackButton -->
    <TextView
        android:id="@+id/searchBackButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/back_to_home"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:layout_marginBottom="12dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/search_events"
        android:textColor="#FFFFFF"
        android:textSize="28sp"
        android:textStyle="bold"
        android:layout_marginBottom="16sp"/>

    <!-- Filter container -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#2A2A2A"
        android:orientation="vertical"
        android:padding="12dp">

        <!-- Keyword search -->
        <EditText
            android:id="@+id/searchKeywordInput"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:background="@android:color/transparent"
            android:hint="@string/search_by_keyword_optional"
            android:textColor="#FFFFFF"
            android:textColorHint="#AFAFAF" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#8C8C8C"
            android:layout_marginBottom="8dp"/>

        <!-- Tag dropdown -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/event_tag_prompt"
            android:textColor="#E6E6E6"
            android:textSize="14sp" />

        <Spinner
            android:id="@+id/searchTagSpinner"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:background="@android:color/transparent"
            android:entries="@array/event_tags" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#8C8C8C"
            android:layout_marginBottom="8dp"/>

        <!-- Date range pickers -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/date_range_optional"
            android:textColor="#E6E6E6"
            android:textSize="14sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="4dp">

            <EditText
                android:id="@+id/searchStartDate"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:background="@android:color/transparent"
                android:hint="@string/start_date"
                android:focusable="false"
                android:clickable="true"
                android:textColor="#FFFFFF"
                android:textColorHint="#AFAFAF"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/to"
                android:textColor="#FFFFFF"
                android:layout_gravity="center_vertical"/>

            <EditText
                android:id="@+id/searchEndDate"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:background="@android:color/transparent"
                android:hint="@string/end_date"
                android:focusable="false"
                android:clickable="true"
                android:textColor="#FFFFFF"
                android:textColorHint="#AFAFAF"
                android:gravity="end"/>
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#8C8C8C"
            android:layout_marginBottom="8dp"/>

        <!-- Capacity range filter -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/capacity_range_optional"
            android:textColor="#E6E6E6"
            android:textSize="14sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="4dp">

            <EditText
                android:id="@+id/searchMinCapacity"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:background="@android:color/transparent"
                android:hint="@string/min"
                android:inputType="number"
                android:textColor="#FFFFFF"
                android:textColorHint="#AFAFAF" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/to_cap"
                android:textColor="#FFFFFF"
                android:layout_gravity="center_vertical"/>

            <EditText
                android:id="@+id/searchMaxCapacity"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:background="@android:color/transparent"
                android:hint="@string/max_search"
                android:inputType="number"
                android:textColor="#FFFFFF"
                android:textColorHint="#AFAFAF"
                android:gravity="end"/>
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#8C8C8C"
            android:layout_marginBottom="12dp"/>

        <!-- Action buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/clearFiltersButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:backgroundTint="#555555"
                android:text="@string/clear"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"/>

            <Button
                android:id="@+id/applySearchButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="2"
                android:backgroundTint="#EAEAEA"
                android:text="@string/search"
                android:textAllCaps="false"
                android:textColor="#000000"
                android:textStyle="bold"/>
        </LinearLayout>
    </LinearLayout>

    <!-- results list -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="@string/results"
        android:textColor="#FFFFFF"
        android:textSize="20sp"
        android:textStyle="bold"/>

    <ListView
        android:id="@+id/searchResultsList"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="8dp"
        android:divider="@android:color/transparent"
        android:dividerHeight="0dp"/>

</LinearLayout>
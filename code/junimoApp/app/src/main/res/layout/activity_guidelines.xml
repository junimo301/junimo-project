<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingTop="16dp"
            android:paddingEnd="16dp"
            android:paddingBottom="16dp">

            <TextView
                android:id="@+id/titleGuidelines"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/event_lottery"
                android:textColor="#FFFFFF"
                android:textSize="28sp"
                android:textStyle="bold" />

            <ImageButton
                android:id="@+id/guidelinesSettingsButton"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@android:color/transparent"
                android:contentDescription="@string/settings"
                android:src="@android:drawable/ic_menu_manage"
                android:tint="#FFFFFF" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#2A2A2A" />

        <TextView
            android:id="@+id/guidelinesBackButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="14dp"
            android:text="@string/back_to_home"
            android:textColor="#FFFFFF"
            android:textSize="18sp" />

        <TextView
            android:id="@+id/guidelinesText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingBottom="16dp"
            android:textColor="#E6E6E6"
            android:textSize="15sp"
            android:lineSpacingExtra="4dp"
            android:text="@string/_1_purpose_of_the_app_10_10_the_event_lottery_system_helps_people_register_for_popular_community_events_in_a_fair_way_instead_of_spots_being_taken_by_whoever_clicks_first_users_can_join_a_waiting_list_and_are_selected_randomly_10_10_this_system_gives_everyone_a_fair_chance_to_participate_even_if_they_cannot_register_immediately_when_an_event_opens_10_10_2_general_rules_10_10_to_keep_the_platform_fair_and_enjoyable_for_everyone_please_follow_these_rules_10_10_each_user_may_join_the_waiting_list_once_per_event_10_users_should_provide_accurate_personal_information_when_registering_10_if_selected_for_an_event_users_must_accept_or_decline_the_invitation_within_the_given_time_10_if_there_is_no_response_the_spot_may_be_offered_to_another_entrant_10_10_3_how_the_lottery_works_10_10_users_join_the_waiting_list_during_the_event_registration_period_10_when_registration_closes_the_system_randomly_selects_participants_10_selected_users_receive_a_notification_inviting_them_to_register_10_if_someone_declines_or_does_not_respond_another_person_from_the_waiting_list_may_be_selected_10_this_process_continues_until_all_available_spots_are_filled_10_10_4_responsibilities_of_entrants_10_10_join_waiting_lists_only_for_events_they_plan_to_attend_10_respond_to_invitations_as_soon_as_possible_10_follow_any_rules_set_by_the_event_organizer_10_keep_their_profile_information_up_to_date_10_entrants_can_leave_a_waiting_list_at_any_time_before_the_lottery_draw_10_10_5_responsibilities_of_organizers_10_10_provide_clear_and_accurate_event_details_date_time_location_capacity_10_set_registration_start_and_end_dates_10_use_the_lottery_system_fairly_10_communicate_updates_to_entrants_through_the_app_10_organizers_may_update_or_cancel_events_if_necessary_10_10_6_qr_code_access_10_10_events_may_include_a_qr_code_to_make_registration_easier_scanning_a_qr_code_takes_users_directly_to_the_event_page_where_they_can_view_details_and_join_the_waiting_list_qr_codes_should_only_be_used_for_legitimate_event_promotion_10_10_7_location_verification_10_10_some_events_may_require_location_verification_if_enabled_the_app_may_check_device_location_when_users_join_the_waiting_list_location_data_is_used_only_for_this_purpose_10_10_8_notifications_10_10_the_app_may_send_notifications_when_10_a_user_is_selected_for_an_event_10_a_user_is_not_selected_10_an_event_is_updated_or_cancelled_10_organizers_send_important_announcements_10_10_users_can_choose_to_disable_notifications_in_settings_10_10_9_privacy_and_data_10_10_personal_information_is_stored_securely_using_firebase_and_only_used_for_event_registration_and_communication_users_can_delete_their_profile_at_any_time_10_10_10_administrative_oversight_10_10_administrators_help_manage_the_platform_by_removing_inappropriate_events_removing_abusive_profiles_managing_uploaded_images_and_reviewing_notification_logs_10_10_11_fair_use_10_10_users_who_misuse_the_platform_may_be_removed_examples_include_creating_multiple_accounts_to_increase_lottery_chances_uploading_inappropriate_offensive_content_or_violating_platform_guidelines" />

    </LinearLayout>

</ScrollView>

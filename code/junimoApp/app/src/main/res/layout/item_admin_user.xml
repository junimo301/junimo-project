<?xml version="1.0" encoding="utf-8"?>

<!-- Layout for one user item for the admin stuff -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="horizontal"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="12dp"
    android:gravity="center_vertical">

    <!-- User's name and email container -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <!-- displays user name -->
        <TextView
            android:id="@+id/adminUserName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="16sp"
            android:textStyle="bold"
            android:text="User Name" />

        <!-- displays user email -->
        <TextView
            android:id="@+id/adminUserEmail"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="13sp"
            android:text="user.email@example.com" />

    </LinearLayout>

    <!-- button for profile deleting -->
    <Button
        android:id="@+id/adminUserDeleteButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Remove"
        android:backgroundTint="#990F02"
        android:textColor="#FFFFFF" />

</LinearLayout>
<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">


    <LinearLayout
        android:layout_width="409dp"
        android:layout_height="729dp"
        android:orientation="vertical"
        tools:layout_editor_absoluteX="1dp"
        tools:layout_editor_absoluteY="1dp">


        <TextView
            android:id="@+id/preview_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="preview_title" />


        <TextView
            android:id="@+id/preview_description"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="preview_description" />


        <TextView
            android:id="@+id/preview_start_date"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="preview_start_date" />


        <TextView
            android:id="@+id/preview_end_date"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="preview_end_date" />


        <TextView
            android:id="@+id/preview_date"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="preview_date" />


        <TextView
            android:id="@+id/preview_event_location"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="preview_event_location" />


        <TextView
            android:id="@+id/preview_max_capacity"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="preview_max_capacity" />


        <TextView
            android:id="@+id/preview_waiting_list"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="preview_waiting_list" />


        <TextView
            android:id="@+id/preview_price"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="preview_price" />


        <TextView
            android:id="@+id/preview_geo_location"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="preview_geo_location" />


        <Button
            android:id="@+id/back_button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="back_button" />
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>

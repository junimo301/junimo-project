<?xml version="1.0" encoding="utf-8"?>
<!--
    US 02.01.03
    A single row in the search results list inside PrivateInviteActivity.
    Shows the user's name, email/phone, and an Invite button.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="#1A1A1A"
    android:orientation="horizontal"
    android:padding="12dp">

    <!-- User name and contact info (takes all remaining width) -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_gravity="center_vertical"
        android:layout_weight="1"
        android:orientation="vertical">

        <!-- User's name -->
        <TextView
            android:id="@+id/user_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold" />

        <!-- Email and/or phone shown on one line -->
        <TextView
            android:id="@+id/user_sub"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:textColor="#AFAFAF"
            android:textSize="13sp" />

    </LinearLayout>

    <!--
        US 02.01.03
        Invite button — organizer taps this to send an invitation
        to this specific entrant.
    -->
    <Button
        android:id="@+id/invite_button"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_vertical"
        android:backgroundTint="#D9D9D9"
        android:text="@string/invite"
        android:textAllCaps="false"
        android:textColor="#000000"
        android:textSize="14sp" />

</LinearLayout>
<?xml version="1.0" encoding="utf-8"?>
<!--
    Layout for NotificationsActivity.
    US 01.04.01 — shows invite notifications
    US 01.04.02 — shows not-chosen notifications
    US 01.05.06 — shows private event invite notifications
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Event Lottery"
        android:textColor="#FFFFFF"
        android:textSize="28sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="Notifications"
        android:textColor="#D2D2D2"
        android:textSize="16sp" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="14dp"
        android:background="#2A2A2A" />

    <!--
        US 01.04.01 / 01.04.02 / 01.05.06
        List of notification messages, newest first.
        Each row shows one notification message string.
    -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/notificationsRecycler"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginBottom="12dp" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#2A2A2A" />

    <!-- Back navigation -->
    <TextView
        android:id="@+id/backToHomeNotif"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:padding="8dp"
        android:text="← Back to Home"
        android:textColor="#FFFFFF"
        android:textSize="16sp" />

</LinearLayout>
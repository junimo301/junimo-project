<?xml version="1.0" encoding="utf-8"?>

<!-- Layout for one image row in the admin browsing screen -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="horizontal"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="12dp"
    android:gravity="center_vertical">

    <ImageView
        android:id="@+id/adminImageThumbnail"
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:contentDescription="@string/no_image"
        android:scaleType="centerCrop"/>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:layout_marginStart="12dp"
        android:orientation="vertical">

        <TextView
            android:id="@+id/adminImageType"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#AFAFAF"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/adminImageLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:textStyle="bold"/>
    </LinearLayout>

    <Button
        android:id="@+id/adminImageDeleteButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:backgroundTint="#C0392B"
        android:text="@string/remove_image"
        android:textColor="#FFFFFF"
        android:textSize="12sp"/>

</LinearLayout>